# Kopieer dit bestand naar .env en pas waarden aan:
#   PowerShell:  Copy-Item .env.example .env
#   Git Bash:    cp .env.example .env

# Poort waarop Open WebUI in de browser bereikbaar is.
WEBUI_PORT=3000

# Ollama draait native op de Windows-host (aanbevolen, beste GPU-support).
# Laat dit zo staan bij de standaard-setup.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Geheime sleutel voor sessies/cookies. Genereer een willekeurige waarde, bv.:
#   PowerShell:  [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
WEBUI_SECRET_KEY=change-me-to-a-random-string
